{
  "name": "logbook",
  "private": true,
  "version": "0.4.4",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "node scripts/ensure-version-bumped.mjs && tauri build --config src-tauri/tauri.conf.prod.json",
    "tauri:build:dev": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "vitest run && vue-tsc --noEmit && vite build",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "reka-ui": "^2.9.10",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.10"
  }
}
